{
  "page": "DemoFormPage",
  "testCases": [
    {
      "name": "Smoke Test",
      "data": {
        "firstName": "Rajib",
        "subscribe": true,
        "genderMale": true,
        "state": "California",
        "city": "San Jose"
      },
      "tables": [
        {
          "tableKey": "usersTable",
          "id": "inactive_user_check",
          "verify": [
            {
              "match": {
                "Name": "Jane Doe",
                "Status": "INACTIVE"
              },
              "assert": {
                "Status": "INACTIVE"
              }
            }
          ]
        },
        {
          "tableKey": "usersGrid",
          "id": "link_clicked",
          "verify": [
            {
              "match": {
                "Name": "Alice"
              },
              "assert": {
                "Status": "CLICKED"
              }
            }
          ]
        }
      ]
    },

    {
      "name": "demoForm_tableVerification_containsAssertion",
      "tables": [
        {
          "tableKey": "usersGrid",
          "id": "status_contains_click",
          "verify": [
            {
              "match": {
                "Name": "Alice"
              },
              "assert": {
                "Status": {
                  "type": "CONTAINS",
                  "value": "ACTIVE"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
