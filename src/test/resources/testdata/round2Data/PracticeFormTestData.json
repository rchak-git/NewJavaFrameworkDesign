[
  {
    "scenarioId": "ValidFormPopulation",
    "steps": [
      { "fieldKey": "firstName",      "intent": "populate", "value": "${firstName}" },
      { "fieldKey": "lastName",       "intent": "populate", "value": "${lastName}" },
      { "fieldKey": "userEmail",      "intent": "populate", "value": "${userEmail}" },
      { "fieldKey": "userNumber",     "intent": "populate", "value": "${userNumber}" },
      { "fieldKey": "gender",         "intent": "populate", "value": "${gender}" },
      { "fieldKey": "subjectsInput",  "intent": "populate", "value": "${subjectsInput}" },
      { "fieldKey": "currentAddress", "intent": "populate", "value": "${currentAddress}" }
    ]
  },
  {
    "testName": "Test1_PopulateFourFieldsAndSubmit",
    "scenario": [
      {
        "use": "ValidFormPopulation",
        "parameters": {
          "firstName": "John",
          "lastName": "Doe",
          "userEmail": "CTX_EMAIL",
          "userNumber": "1234567890"
        }
      },
      { "fieldKey": "submit", "intent": "action", "actionType": "CLICK" }
    ]
  }
]